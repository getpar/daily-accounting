# ===== 依赖文件夹（第三方库，体积巨大，不需要上传） =====
node_modules/

# ===== 构建产物（编译后生成的，不需要上传） =====
dist/
release/
out/

# ===== 环境配置文件（可能含敏感信息） =====
.env
.env.local
.env.*.local

# ===== 系统文件 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== IDE / 编辑器文件 =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== 编译缓存 =====
.swc/

# ===== 临时文件 =====
*.log
*.tmp
.cache/
